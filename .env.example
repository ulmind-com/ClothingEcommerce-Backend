# --- App ---
APP_NAME=ClothingEcommerce
ENV=development

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB=clothing_ecommerce

# --- JWT ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# --- CORS ---
CORS_ORIGINS=*

# --- Razorpay ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Cloudinary (image uploads) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Firebase Admin (fill later, path to service account json) ---
FIREBASE_CREDENTIALS=
